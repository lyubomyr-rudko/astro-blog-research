---
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const withBase = (path) => `${baseUrl}${path.replace(/^\/+/, "")}`;

const blogEntries = await getCollection("blog");

const cleanMarkdownParagraph = (paragraph: string) =>
  paragraph
    .replace(/\\([\\`*_[\]{}()#+\-.!>])/g, "$1")
    .replace(/<[^>]+>/g, " ")
    .replace(/!\[[^\]]*\]\([^)]+\)/g, "")
    .replace(/\[([^\]]+)\]\([^)]+\)/g, "$1")
    .replace(/^[\s>]+/gm, "")
    .replace(/[*_`~]/g, "")
    .replace(/\s+/g, " ")
    .trim();

const getOpeningParagraphs = (
  body: string,
  {
    fallback,
    title,
    date,
  }: { fallback?: string; title?: string; date?: string } = {},
) => {
  const cleanTitle = title ? cleanMarkdownParagraph(title) : "";
  const paragraphs = body
    .replace(/<img[\s\S]*?\/>/g, "")
    .replace(/<iframe[\s\S]*?<\/iframe>/g, "")
    .split(/\n{2,}/)
    .map((paragraph) => paragraph.trim())
    .filter(
      (paragraph) =>
        paragraph &&
        !paragraph.startsWith("#") &&
        !paragraph.startsWith("---") &&
        !paragraph.startsWith("<"),
    )
    .map(cleanMarkdownParagraph)
    .filter((paragraph) => {
      const normalized = paragraph.toLocaleLowerCase("uk-UA");
      return (
        paragraph.length >= 20 &&
        paragraph !== date &&
        paragraph !== cleanTitle &&
        !normalized.startsWith("проповіді джона веслі")
      );
    })
    .slice(0, 2);

  if (paragraphs.length > 0) return paragraphs;
  return fallback ? [fallback] : [];
};

const getDateKey = (date = new Date()) =>
  [
    date.getFullYear(),
    String(date.getMonth() + 1).padStart(2, "0"),
    String(date.getDate()).padStart(2, "0"),
  ].join("-");

const getDateHash = (dateKey: string) =>
  [...dateKey].reduce(
    (hash, character) => (hash * 31 + character.charCodeAt(0)) >>> 0,
    0,
  );

const getDailySermon = <
  Sermon extends {
    title: string;
    date: string;
    url: string;
    excerpt: string[];
  },
>(
  sermons: Sermon[],
  dateKey: string,
) => sermons[getDateHash(dateKey) % sermons.length];

const sermonSummaries = blogEntries
  .filter((post) => post.id.startsWith("sermons/"))
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((post) => ({
    title: post.data.title,
    date: post.data.pubDate ?? "",
    url: withBase(`/${post.id}/`),
    excerpt: getOpeningParagraphs(post.body, {
      fallback: post.data.description,
      title: post.data.title,
      date: post.data.pubDate,
    }),
  }));
const todayDateKey = getDateKey();
const dailySermon = sermonSummaries.length
  ? getDailySermon(sermonSummaries, todayDateKey)
  : undefined;
const sermonSummariesJson = JSON.stringify(sermonSummaries).replace(
  /</g,
  "\\u003c",
);

const posts = blogEntries
  .filter(
    (post) =>
      !post.id.startsWith("sermons/") && !post.id.startsWith("church-in-lviv/"),
  )
  .sort((a, b) => (b.data.pubDate ?? "").localeCompare(a.data.pubDate ?? ""));
const churchPosts = blogEntries
  .filter((post) => post.id.startsWith("church-in-lviv/"))
  .sort((a, b) => (b.data.pubDate ?? "").localeCompare(a.data.pubDate ?? ""))
  .slice(0, 3);
type BlogPostEntry = CollectionEntry<"blog">;
---

<BaseLayout
  title="Центр Джона Веслі"
  description="Переклади, дослідження та матеріали про життя, проповідь і духовну спадщину Джона Веслі."
>
  <div class="home-shell home-effects" data-home-scroll>
    <section class="home-hero" data-reveal>
      <div class="home-hero-copy">
        <p class="home-kicker">We love as Christ loved</p>
        <h1 class="home-title">Центр Джона Веслі</h1>
        <p class="home-summary">
          Переклади, дослідження та добірка матеріалів про життя, проповідь,
          богослов'я і духовну спадщину Джона Веслі для українського читача.
        </p>

        <div class="home-actions">
          <a class="button-primary" href={dailySermon?.url ?? "#materials"}>
            Читати проповіді Джона Веслея
          </a>
          {
            posts[0] && (
              <a class="button-secondary" href={withBase(`/${posts[0].id}/`)}>
                Відкрити останню публікацію
              </a>
            )
          }
        </div>

        <h4 class="church-address home-youtube-link">
          Приєднайтеся до нашої групи в{" "}
          <a
            href="https://youtu.be/dotQFbne868?si=7XQK-TYYMqYSW2iJ"
            class="archive-inline-link"
          >
            YouTube
          </a>
        </h4>
      </div>

      <div class="home-hero-visual">
        <img
          class="home-hero-image"
          src={withBase("/images/wesley-preaching.png")}
          alt="Джон Веслі проповідує просто неба перед зібранням слухачів"
          loading="eager"
          data-home-image
        />
      </div>
    </section>

    <section class="mission-card" data-reveal>
      <p class="mission-label">Спадщина Веслі</p>
      <h2 class="mission-title">Святість серця і життя</h2>
      <p class="mission-text">
        Сайт збирає тексти, що показують, як проповідь благодаті, дисципліна
        духовного життя і служіння ближньому формували методистський рух.
      </p>
    </section>

    {
      dailySermon && (
        <section
          class="archive-card daily-sermon-card"
          data-daily-sermon
          data-reveal
        >
          <div class="archive-header">
            <p class="archive-eyebrow">Проповідь дня</p>
            <h2>Проповідь Джона Веслі на сьогодні</h2>
            <p class="archive-summary">
              Проповідь з підбірки з 140 класичних проповідей Джона Веслі.
            </p>
          </div>

          <ul class="post-list">
            <li class="post-item" data-reveal>
              <a
                class="post-link"
                data-daily-sermon-link
                href={dailySermon.url}
              >
                {dailySermon.date && (
                  <span class="post-date" data-daily-sermon-date>
                    {dailySermon.date}
                  </span>
                )}
                <span class="post-title" data-daily-sermon-title>
                  {dailySermon.title}
                </span>
                <div
                  class="post-description daily-sermon-excerpt"
                  data-daily-sermon-excerpt
                >
                  {dailySermon.excerpt.map((paragraph) => (
                    <p>{paragraph}</p>
                  ))}
                </div>
                <span class="button-secondary daily-sermon-button">
                  Читати далі
                </span>
              </a>
            </li>
          </ul>
        </section>
      )
    }

    {
      churchPosts.length > 0 && (
        <section class="archive-card" data-reveal>
          <div class="archive-header">
            <p class="archive-eyebrow">Церква у Львові</p>
            <h2>Свіжі записи богослужінь</h2>

            <p class="archive-summary">
              <hr />
              <h4 class="church-address">
                Завітайте до нас у неділю{" "}
                <>
                  <strong> 11:00</strong>
                  <br />
                </>{" "}
                м. Львів, площа Григоренка 5
              </h4>
              <hr />
              <h4 class="church-address">
                Приєднайдеся до нашої групи в
                <a
                  href="https://youtu.be/dotQFbne868?si=7XQK-TYYMqYSW2iJ"
                  class="archive-inline-link"
                >
                  YouTube
                </a>
              </h4>
            </p>
            <p class="archive-summary">
              <a class="archive-inline-link" href={withBase("/church/")}>
                Архів богослужінь церкви
              </a>
            </p>
          </div>

          <ul class="post-list">
            {churchPosts.map((post: BlogPostEntry, index) => (
              <li
                class="post-item"
                data-reveal
                style={`--reveal-delay: ${Math.min(index, 8) * 45}ms`}
              >
                <a class="post-link" href={withBase(`/${post.id}/`)}>
                  {post.data.pubDate && (
                    <span class="post-date">{post.data.pubDate}</span>
                  )}
                  <span class="post-title">{post.data.title}</span>
                  {post.data.description && (
                    <p class="post-description">{post.data.description}</p>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="archive-card" id="materials" data-reveal>
      <div class="archive-header">
        <p class="archive-eyebrow">Матеріали центру</p>
        <h2>Читайте тексти про Джона Веслі та методизм</h2>
        <p class="archive-summary">
          Загалом на сайті: <span class="count">{posts.length}</span> сторінок
        </p>
      </div>

      <ul class="post-list">
        {
          posts.map((post: BlogPostEntry, index) => (
            <li
              class="post-item"
              data-reveal
              style={`--reveal-delay: ${Math.min(index, 8) * 45}ms`}
            >
              <a class="post-link" href={withBase(`/${post.id}/`)}>
                {post.data.pubDate && (
                  <span class="post-date">{post.data.pubDate}</span>
                )}
                <span class="post-title">{post.data.title}</span>
                {post.data.description && (
                  <p class="post-description">{post.data.description}</p>
                )}
              </a>
            </li>
          ))
        }
      </ul>
    </section>
  </div>

  <script
    type="application/json"
    data-daily-sermons-source
    set:html={sermonSummariesJson}
  />

  <style>
    .home-effects {
      --home-scroll-progress: 0;
      --home-bg-y: 0px;
      --home-hero-bg-y: 0px;
      --home-archive-bg-y: 0px;
      --home-image-y: 0px;
      --home-image-scale: 1.06;
      --home-light-x: -18px;
      position: relative;
      isolation: isolate;
    }

    .home-effects::before {
      content: "";
      position: absolute;
      inset: -2rem -1.4rem -1rem;
      z-index: -1;
      border-radius: 32px;
      background:
        repeating-linear-gradient(
          0deg,
          rgba(188, 169, 146, 0.12) 0,
          rgba(188, 169, 146, 0.12) 1px,
          transparent 1px,
          transparent 46px
        ),
        linear-gradient(115deg, rgba(178, 31, 45, 0.08), transparent 36%),
        linear-gradient(
          180deg,
          rgba(255, 253, 249, 0),
          rgba(247, 241, 232, 0.5)
        );
      opacity: 0.62;
      pointer-events: none;
      transform: translate3d(0, var(--home-bg-y), 0);
      will-change: transform;
    }

    .home-effects .home-hero {
      isolation: isolate;
      background:
        linear-gradient(118deg, rgba(178, 31, 45, 0.1), transparent 46%),
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.94),
          rgba(255, 251, 245, 0.96)
        );
    }

    .home-effects .home-hero::before {
      content: "";
      position: absolute;
      inset: -12% 0;
      z-index: 0;
      background:
        repeating-linear-gradient(
          104deg,
          rgba(132, 16, 31, 0.08) 0,
          rgba(132, 16, 31, 0.08) 1px,
          transparent 1px,
          transparent 28px
        ),
        linear-gradient(
          90deg,
          rgba(247, 241, 232, 0.52),
          rgba(255, 253, 249, 0)
        );
      opacity: 0.42;
      pointer-events: none;
      transform: translate3d(0, var(--home-hero-bg-y), 0);
      will-change: transform;
    }

    .home-effects .home-hero::after {
      display: none;
    }

    .home-effects .home-title {
      letter-spacing: 0;
    }

    .home-effects .home-hero-visual {
      transition:
        box-shadow 220ms ease,
        transform 220ms ease;
    }

    .home-effects .home-hero-visual::before {
      content: "";
      position: absolute;
      inset: -30% 48% -30% -35%;
      z-index: 1;
      background: linear-gradient(
        100deg,
        rgba(255, 255, 255, 0),
        rgba(255, 255, 255, 0.42),
        rgba(255, 255, 255, 0)
      );
      transform: translate3d(var(--home-light-x), 0, 0) rotate(12deg);
      mix-blend-mode: screen;
      opacity: 0.55;
      pointer-events: none;
      will-change: transform;
    }

    .home-effects .home-hero-image {
      transform: translate3d(0, var(--home-image-y), 0)
        scale(var(--home-image-scale));
      transform-origin: center;
      will-change: transform;
    }

    .home-effects .mission-card,
    .home-effects .archive-card {
      position: relative;
      overflow: hidden;
    }

    .home-effects .mission-card::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        linear-gradient(
          90deg,
          rgba(255, 246, 240, 0.08),
          transparent 42%,
          rgba(255, 246, 240, 0.12)
        ),
        repeating-linear-gradient(
          0deg,
          rgba(255, 246, 240, 0.12) 0,
          rgba(255, 246, 240, 0.12) 1px,
          transparent 1px,
          transparent 38px
        );
      opacity: calc(0.22 + var(--home-scroll-progress) * 0.32);
      pointer-events: none;
    }

    .home-effects .archive-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        145deg,
        rgba(178, 31, 45, 0.06),
        transparent 34%,
        rgba(56, 74, 87, 0.05)
      );
      opacity: 0.58;
      pointer-events: none;
      transform: translate3d(0, var(--home-archive-bg-y), 0);
      will-change: transform;
    }

    .home-effects .archive-card > * {
      position: relative;
      z-index: 1;
    }

    .home-effects .archive-inline-link {
      color: var(--accent-dark);
      font-weight: 800;
      text-decoration: none;
    }

    .home-effects .archive-inline-link:hover {
      color: var(--accent);
    }

    .home-effects.is-ready [data-reveal] {
      --reveal-y: 18px;
      opacity: 0;
      transform: translate3d(0, var(--reveal-y), 0);
      transition:
        opacity 650ms ease,
        transform 650ms cubic-bezier(0.2, 0.8, 0.2, 1);
      transition-delay: var(--reveal-delay, 0ms);
    }

    .home-effects.is-ready [data-reveal].is-visible {
      --reveal-y: 0px;
      opacity: 1;
    }

    .home-effects.is-ready .post-item[data-reveal] {
      --reveal-y: 12px;
    }

    .home-effects.is-ready .post-item[data-reveal].is-visible {
      --reveal-y: 0px;
    }

    .home-effects .post-link {
      position: relative;
      z-index: 1;
    }

    .home-effects .home-youtube-link {
      margin-top: 3rem;
    }

    .home-effects .daily-sermon-excerpt p {
      margin: 0;
    }

    .home-effects .daily-sermon-excerpt p + p {
      margin-top: 0.65rem;
    }

    .home-effects .daily-sermon-button {
      margin-top: 1rem;
    }

    @media (max-width: 720px) {
      .home-effects::before {
        inset: -1.2rem -0.6rem -0.6rem;
      }

      .home-effects .home-hero-visual::before {
        opacity: 0.38;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .home-effects,
      .home-effects *,
      .home-effects *::before,
      .home-effects *::after {
        scroll-behavior: auto;
        transition-duration: 1ms !important;
        animation-duration: 1ms !important;
      }

      .home-effects::before,
      .home-effects .home-hero::before,
      .home-effects .archive-card::before,
      .home-effects .home-hero-visual::before,
      .home-effects .home-hero-image {
        transform: none;
      }

      .home-effects.is-ready [data-reveal] {
        --reveal-y: 0px;
        opacity: 1;
        transform: none;
      }
    }
  </style>

  <script>
    const dailySermonsSource = document.querySelector(
      "[data-daily-sermons-source]",
    );
    const dailySermonCard = document.querySelector("[data-daily-sermon]");

    if (dailySermonsSource && dailySermonCard instanceof HTMLElement) {
      const getDailyDateKey = (date = new Date()) =>
        [
          date.getFullYear(),
          String(date.getMonth() + 1).padStart(2, "0"),
          String(date.getDate()).padStart(2, "0"),
        ].join("-");
      const getDailyDateHash = (dateKey) =>
        [...dateKey].reduce(
          (hash, character) => (hash * 31 + character.charCodeAt(0)) >>> 0,
          0,
        );

      try {
        const sermons = JSON.parse(dailySermonsSource.textContent || "[]");
        const sermon = sermons.length
          ? sermons[getDailyDateHash(getDailyDateKey()) % sermons.length]
          : null;

        if (sermon) {
          const link = dailySermonCard.querySelector(
            "[data-daily-sermon-link]",
          );
          const date = dailySermonCard.querySelector(
            "[data-daily-sermon-date]",
          );
          const title = dailySermonCard.querySelector(
            "[data-daily-sermon-title]",
          );
          const excerpt = dailySermonCard.querySelector(
            "[data-daily-sermon-excerpt]",
          );

          if (link instanceof HTMLAnchorElement) link.href = sermon.url;
          if (date) date.textContent = sermon.date;
          if (title) title.textContent = sermon.title;
          if (excerpt) {
            excerpt.replaceChildren(
              ...sermon.excerpt.map((paragraph) => {
                const element = document.createElement("p");
                element.textContent = paragraph;
                return element;
              }),
            );
          }
        }
      } catch {
        dailySermonCard.removeAttribute("data-daily-sermon-live");
      }
    }

    const homeRoot = document.querySelector("[data-home-scroll]");

    if (homeRoot instanceof HTMLElement) {
      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      );
      const revealItems = Array.from(
        homeRoot.querySelectorAll("[data-reveal]"),
      );

      homeRoot.classList.add("is-ready");

      if (reduceMotion.matches || !("IntersectionObserver" in window)) {
        revealItems.forEach((item) => item.classList.add("is-visible"));
      } else {
        const revealObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                revealObserver.unobserve(entry.target);
              }
            });
          },
          {
            rootMargin: "0px 0px -10% 0px",
            threshold: 0.16,
          },
        );

        revealItems.forEach((item) => revealObserver.observe(item));
      }

      if (!reduceMotion.matches) {
        let ticking = false;

        const updateScrollEffects = () => {
          const viewportHeight = window.innerHeight || 1;
          const rootRect = homeRoot.getBoundingClientRect();
          const scrollableDistance = Math.max(
            homeRoot.offsetHeight - viewportHeight,
            1,
          );
          const progress = Math.min(
            Math.max(-rootRect.top / scrollableDistance, 0),
            1,
          );

          homeRoot.style.setProperty(
            "--home-scroll-progress",
            progress.toFixed(4),
          );
          homeRoot.style.setProperty(
            "--home-bg-y",
            `${(progress * 42).toFixed(1)}px`,
          );
          homeRoot.style.setProperty(
            "--home-hero-bg-y",
            `${(progress * -26).toFixed(1)}px`,
          );
          homeRoot.style.setProperty(
            "--home-archive-bg-y",
            `${(progress * 22).toFixed(1)}px`,
          );
          homeRoot.style.setProperty(
            "--home-image-y",
            `${(progress * -34).toFixed(1)}px`,
          );
          homeRoot.style.setProperty(
            "--home-image-scale",
            `${(1.06 + progress * 0.025).toFixed(3)}`,
          );
          homeRoot.style.setProperty(
            "--home-light-x",
            `${(-18 + progress * 74).toFixed(1)}px`,
          );

          ticking = false;
        };

        const queueScrollEffects = () => {
          if (ticking) return;
          ticking = true;
          window.requestAnimationFrame(updateScrollEffects);
        };

        updateScrollEffects();
        window.addEventListener("scroll", queueScrollEffects, {
          passive: true,
        });
        window.addEventListener("resize", queueScrollEffects);
      }
    }
  </script>
</BaseLayout>
